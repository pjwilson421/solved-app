# Copy to `.env.local` and fill in values (no spaces around `=`).
# Restart the dev server after changes.

# --- Google Gemini (image generation, video generation) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Alternative env names also read by `app/api/ai/generate-image/route.ts`:
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_AI_API_KEY=

# Optional override for the image model (default: gemini-2.5-flash-image)
# GEMINI_IMAGE_MODEL=

# --- Anthropic Claude (chat API) ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
