# Copy to `.env.local` and fill in values. No spaces around `=`.
# Gemini (image + video API routes)
GEMINI_API_KEY=
# Alternate key names accepted by the image generation route (optional; use one)
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_AI_API_KEY=
# Optional override for Gemini image model (defaults in code if unset)
GEMINI_IMAGE_MODEL=
# Anthropic (chat API route)
ANTHROPIC_API_KEY=
